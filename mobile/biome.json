{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"ignore": []
	},
	"formatter": {
		"enabled": true,
    "indentStyle": "tab",
    "lineWidth": 80,
    "attributePosition": "auto",
    "ignore": []
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
    "ignore": ["src/components/Graph/plugins/zoom.js"],
		"enabled": true,
		"rules": {
			"recommended": true,
      "suspicious": {
        "noExplicitAny": "warn"
      }
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "bracketSameLine": false
		}
	}
}
